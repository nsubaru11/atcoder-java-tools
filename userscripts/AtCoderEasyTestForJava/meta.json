{
	"name": "AtCoder Easy Test for Java",
	"name:en": "AtCoder Easy Test for Java",
	"version": "1.6.4",
	"description": "AtCoder, yukicoder, Codeforces でのサンプルテストを自動化します。Java 向けに最適化されています。",
	"description:ja": "AtCoder, yukicoder, Codeforces でのサンプルテストを自動化します。Java 向けに最適化されています。",
	"description:en": "Automates sample testing on AtCoder, yukicoder, and Codeforces. Optimized for Java.",
	"author": "magurofly (original), nsubaru (modified)",
	"match": [
		"https://atcoder.jp/contests/*/tasks/*",
		"https://atcoder.jp/contests/*/submit*",
		"https://yukicoder.me/problems/no/*",
		"https://yukicoder.me/problems/*",
		"https://codeforces.com/contest/*/problem/*",
		"https://codeforces.com/gym/*/problem/*",
		"https://codeforces.com/problemset/problem/*",
		"https://codeforces.com/group/*/contest/*/problem/*",
		"https://*.contest.codeforces.com/group/*/contest/*/problem/*",
		"https://m1.codeforces.com/contest/*/problem/*",
		"https://m2.codeforces.com/contest/*/problem/*",
		"https://m3.codeforces.com/contest/*/problem/*",
		"https://greasyfork.org/*/scripts/433152-atcoder-easy-test-v2"
	],
	"grant": [
		"unsafeWindow",
		"GM_getValue",
		"GM_setValue"
	],
	"run-at": "document-end"
}
