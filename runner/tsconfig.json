{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"lib": [
			"ES2022",
			"DOM"
		],
		"types": [
			"node"
		],
		"strict": true,
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"skipLibCheck": true,
		"noEmit": true,
		"baseUrl": ".",
		"paths": {
			"@shared/*": [
				"../shared/src/*"
			]
		}
	},
	"include": [
		"src/**/*.ts",
		"../shared/src/**/*.ts"
	]
}
