{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"strict": false,
		"noImplicitAny": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"allowJs": false,
		"esModuleInterop": true,
		"resolveJsonModule": true,
		"isolatedModules": true,
		"forceConsistentCasingInFileNames": true,
		"skipLibCheck": true,
		"lib": [
			"ES2022",
			"DOM",
			"DOM.Iterable"
		],
		"types": [
			"bun"
		],
		"noEmit": true,
		"baseUrl": ".",
		"paths": {
			"@shared/*": [
				"../shared/src/*"
			]
		}
	},
	"include": [
		"build.ts",
		"*/src/**/*.ts",
		"types/**/*.d.ts",
		"../shared/src/**/*.ts"
	]
}
